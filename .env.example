# ============================================================
# Ally X Agents — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- Ollama ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b-q8_0

# --- Microsoft Graph / M365 ---
# Required by: calendar_sync, morning_digest, grocery_optimizer
MS_TENANT_ID=your-tenant-id-here
MS_CLIENT_ID=your-client-id-here

# --- Google APIs ---
# Required by: calendar_sync, morning_digest, commute_ping
# credentials JSON downloaded from Google Cloud Console
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# --- OpenWeatherMap ---
# Required by: morning_digest
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here

# --- Commute ---
# Required by: commute_ping
HOME_ADDRESS=your-home-address-here
BIOSPACE_ADDRESS=11150 Santa Monica Blvd, Los Angeles, CA 90025

# --- Discord ---
# Required by: all agents
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Webhook URLs — one per channel
DISCORD_CALENDAR_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_COMMUTE_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_REMINDERS_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_GROCERIES_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_FINANCE_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_PACKAGES_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_BILLS_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_STATUS_WEBHOOK=https://discord.com/api/webhooks/...
